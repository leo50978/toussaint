rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function validTimestamp(value) {
      return value is timestamp;
    }

    function validStatusType(value) {
      return ["text", "image", "video"].hasAny([value]);
    }

    function hasOnlyKeys(data, keys) {
      return data.keys().hasOnly(keys);
    }

    function validString(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function validPublicStatus(data) {
      return hasOnlyKeys(
          data,
          [
            "ownerId",
            "type",
            "content",
            "storageUrl",
            "createdAt",
            "expiresAt",
            "viewCount",
            "mimeType",
            "fileName",
            "fileSize",
            "originalName",
            "storageBackend",
            "storagePath",
            "createdAtTs",
            "expiresAtTs",
          ],
        ) &&
        validString(data.ownerId, 1, 120) &&
        validStatusType(data.type) &&
        validString(data.content, 0, 700) &&
        validString(data.storageUrl, 0, 2048) &&
        validTimestamp(data.createdAtTs) &&
        validTimestamp(data.expiresAtTs) &&
        data.expiresAtTs > request.time &&
        data.viewCount is int &&
        data.viewCount >= 0;
    }

    match /statuses/{statusId} {
      allow get, list: if validPublicStatus(resource.data);
      allow create, update, delete: if false;
    }

    match /conversations/{document=**} {
      allow read, write: if false;
    }

    match /drafts/{document=**} {
      allow read, write: if false;
    }

    match /settings/{document=**} {
      allow read, write: if false;
    }

    match /ownerSecurity/{document=**} {
      allow read, write: if false;
    }

    match /clientAccessSessions/{document=**} {
      allow read, write: if false;
    }

    match /chatAssets/{document=**} {
      allow read, write: if false;
    }

    match /securityBuckets/{document=**} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
